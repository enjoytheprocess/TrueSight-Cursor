#!/usr/bin/env bash
# Git pre-commit: keep AWP register views in sync and run consistency checks.
# Install: make awp-install-hooks

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! command -v make &>/dev/null; then
  echo "pre-commit: make is required for AWP checks (apt install make)." >&2
  exit 1
fi

make awp-render

if ! git diff --quiet -- .awp-workspace/workspace-build/; then
  echo "pre-commit: generated .awp-workspace views are out of date." >&2
  echo "  Run: make awp-render && git add .awp-workspace/workspace-build/" >&2
  exit 1
fi

make awp-docs-check

exit 0
